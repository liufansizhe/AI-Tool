{
  "name": "next-cli",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- next dev",
    "dev:test": "dotenv -e .env.test -- next dev -p 3001",
    "dev:prod": "dotenv -e .env.production -- next dev -p 3002",
    "build": "next build",
    "build:dev": "dotenv -e .env.development -- next build",
    "build:test": "dotenv -e .env.test -- next build",
    "build:prod": "dotenv -e .env.production -- next build",
    "start": "next start",
    "start:test": "dotenv -e .env.test -- next start -p 3001",
    "start:prod": "dotenv -e .env.production -- next start",
    "lint": "eslint",
    "electron": "npx electron electron/main.js",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && NODE_ENV=development npx electron electron/main.js\"",
    "electron:dev:test": "concurrently \"npm run dev:test\" \"wait-on http://localhost:3001 && npx electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build:prod && electron-builder --win",
    "electron:build:mac": "npm run build:prod && electron-builder --mac",
    "electron:build:linux": "npm run build:prod && electron-builder --linux"
  },
  "build": {
    "appId": "com.example.next-cli",
    "productName": "Next.js Scaffold",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@next/bundle-analyzer": "^16.1.6",
    "antd": "^6.3.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.98.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "wait-on": "^8.0.0"
  }
}
